{
  "name": "assignment-4-flight-tracker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/worker"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:worker": "npm run dev --workspace worker",
    "build:web": "npm run build --workspace web",
    "build:worker": "npm run build --workspace worker",
    "start:worker": "npm run start --workspace worker",
    "lint:web": "npm run lint --workspace web",
    "typecheck": "npm run typecheck --workspace web && npm run typecheck --workspace worker"
  }
}
